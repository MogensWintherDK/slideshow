# Copy to `.env` (which is gitignored) and edit before running
# `docker compose up`.

# REQUIRED — Rails refuses to boot in production without this.
# Generate one with:    openssl rand -hex 64
SECRET_KEY_BASE=

# Where the SQLite database files and the photo source folders are
# stored on the host. Use absolute paths in production.
DATABASE_PATH=./docker-data/db
SLIDES_PATH=./docker-data/slides

# Port the slideshow is reachable on (container always listens on 3000
# internally; this maps to the host).
HOST_PORT=3000

# Local timezone — used for "last seen X ago" formatting in admin etc.
TZ=Europe/Copenhagen

# Optional. If left blank, configure Immich in the admin Settings page
# instead (recommended — the value is then stored in the database).
IMMICH_API_KEY=
IMMICH_BASE_URL=
