#!/usr/bin/env bash
# Bootstrap and start the slideshow server.
# Idempotent: safe to re-run.

set -e
cd "$(dirname "$0")/.."

# Optional: Immich integration.
# The recommended way to configure Immich is the admin Settings page:
#   http://YOUR-IP:3000/admin/settings
# Paste your API key there once and it's stored in the database.
#
# Env vars are also supported as a fallback:
#   IMMICH_API_KEY=xxxxxx bin/start
#   IMMICH_BASE_URL=https://your-immich.example   (optional, default https://immich.mowin.dk)
# Values saved on the Settings page take precedence over env vars.

# 1. Make sure bundler is available
if ! command -v bundle >/dev/null 2>&1; then
  echo "Installing bundler..."
  gem install bundler
fi

# 2. Install gems if Gemfile.lock is missing or out of date
if [ ! -f Gemfile.lock ] || ! bundle check >/dev/null 2>&1; then
  echo "Installing Ruby gems..."
  bundle install
fi

# 3. Create database the first time
if [ ! -f db/development.sqlite3 ]; then
  echo "Creating database..."
  bundle exec rails db:create
fi

# 4. Apply any pending migrations (creates settings/locations tables, etc.)
echo "Applying migrations..."
bundle exec rails db:migrate

# 4b. One-time migration: move photos from public/slides/ → slides/.
#     Files now live outside public/ so they are only ever reachable
#     through the cached /slideshow/albums/:id/images/:id endpoint.
if [ -d "public/slides" ] && [ ! -L "public/slides" ] && [ ! -e "slides" ]; then
  if find public/slides -mindepth 1 \
        \( -iname "*.jpg" -o -iname "*.jpeg" -o -type d \) \
        2>/dev/null | grep -q .; then
    echo "Moving photos: public/slides/ → slides/"
    mv public/slides slides
    mkdir -p public/slides
    : > public/slides/.keep
  fi
fi
mkdir -p slides

# 5. Print local IPs so you can find the right URL on your phone / TV
echo
echo "----------------------------------------------------------"
echo "  Slideshow:  http://<your-ip>:3000/"
echo "  Remote:     http://<your-ip>:3000/remote"
echo
echo "  Likely IPs on this machine:"
if command -v ipconfig >/dev/null 2>&1; then
  for iface in en0 en1 en2; do
    ip=$(ipconfig getifaddr "$iface" 2>/dev/null || true)
    [ -n "$ip" ] && echo "    $iface: $ip"
  done
elif command -v hostname >/dev/null 2>&1; then
  hostname -I 2>/dev/null | tr ' ' '\n' | sed '/^$/d' | sed 's/^/    /'
fi
echo "----------------------------------------------------------"
echo

# 6. Boot
exec bundle exec rails server -b 0.0.0.0 -p "${PORT:-3000}"
