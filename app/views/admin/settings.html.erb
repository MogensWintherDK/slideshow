<h2>Settings</h2>

<% if @settings.any? %>
  <table>
    <thead>
      <tr>
        <th>Key</th>
        <th>Value</th>
        <th>Updated</th>
      </tr>
    </thead>
    <tbody>
      <% @settings.each do |s| %>
        <tr>
          <td class="mono"><%= s.key %></td>
          <td class="mono">
            <%
              decoded = (JSON.parse(s.value) rescue s.value)
              display = case decoded
                        when nil then "null"
                        when true, false then decoded.to_s
                        else decoded.to_s
                        end
            %>
            <%= display.presence || "—" %>
          </td>
          <td class="mono"><%= s.updated_at.strftime("%Y-%m-%d %H:%M") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="card muted">No settings rows.</div>
<% end %>

<h3>Defaults</h3>
<div class="card muted" style="font-size: 13px;">
  Defined in <code>SettingsStore::DEFAULTS</code>:
  <ul style="margin-top: 8px; margin-left: 18px;">
    <% SettingsStore::DEFAULTS.each do |k, v| %>
      <li><code><%= k %></code> = <code><%= v.inspect %></code></li>
    <% end %>
  </ul>
</div>
