<h2>Settings <span class="muted" style="font-weight: 400; font-size: 14px; margin-left: 8px;">legacy</span></h2>

<div class="card muted" style="margin-bottom: 16px; font-size: 13px;">
  Per-group settings (album, play mode, delay, play/pause, birthday timeline) are stored on the
  <a href="<%= admin_groups_path %>">screen groups</a>. Per-screen identity (code, nickname, last seen, current image) is on the
  <a href="<%= admin_screens_path %>">screens</a>. The <code>settings</code> table below is retained for future global flags but currently isn't used.
</div>

<% if @settings.any? %>
  <table>
    <thead>
      <tr>
        <th>Key</th>
        <th>Value</th>
        <th>Updated</th>
      </tr>
    </thead>
    <tbody>
      <% @settings.each do |s| %>
        <tr>
          <td class="mono"><%= s.key %></td>
          <td class="mono">
            <% decoded = (JSON.parse(s.value) rescue s.value) %>
            <%= decoded.to_s.presence || "—" %>
          </td>
          <td class="mono"><%= s.updated_at.strftime("%Y-%m-%d %H:%M") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="card muted">The settings table is currently empty.</div>
<% end %>
