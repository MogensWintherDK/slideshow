<% if total_pages > 1 %>
  <div class="pagination">
    <% if page > 1 %>
      <a href="?page=<%= page - 1 %>">← Previous</a>
    <% else %>
      <span class="disabled">← Previous</span>
    <% end %>
    <span>Page <%= page %> of <%= total_pages %></span>
    <% if page < total_pages %>
      <a href="?page=<%= page + 1 %>">Next →</a>
    <% else %>
      <span class="disabled">Next →</span>
    <% end %>
  </div>
<% end %>
