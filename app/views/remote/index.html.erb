<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
  <title>Slideshow Remote</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0f0f0f;
      --surface: #1c1c1e;
      --border: #2c2c2e;
      --accent: #0a84ff;
      --danger: #ff453a;
      --text: #f2f2f7;
      --text-dim: #8e8e93;
      --radius: 14px;
    }

    html, body {
      min-height: 100vh;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 32px 20px 48px;
      gap: 24px;
    }

    h1 {
      font-size: 20px;
      font-weight: 600;
      letter-spacing: -0.3px;
    }

    .card {
      width: 100%;
      max-width: 380px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }

    .card-title {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--text-dim);
      margin-bottom: 14px;
    }

    #play-pause-btn {
      width: 100%;
      height: 64px;
      border-radius: 12px;
      border: none;
      font-size: 18px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: background 0.15s, transform 0.08s;
      background: var(--accent);
      color: #fff;
    }
    #play-pause-btn:active { transform: scale(0.97); }
    #play-pause-btn.paused  { background: #32d74b; }

    #reset-btn {
      width: 100%;
      height: 52px;
      border-radius: 12px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      background: var(--surface);
      color: var(--danger);
      border: 1.5px solid var(--danger);
      transition: background 0.15s, transform 0.08s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    #reset-btn:active { transform: scale(0.97); background: rgba(255,69,58,0.12); }

    .delay-row { display: flex; align-items: center; gap: 12px; }

    .delay-display {
      font-size: 36px;
      font-weight: 700;
      min-width: 70px;
      text-align: center;
      letter-spacing: -1px;
    }

    .delay-unit {
      font-size: 13px;
      color: var(--text-dim);
      margin-top: 4px;
      text-align: center;
    }

    .stepper { display: flex; flex-direction: column; gap: 8px; flex: 1; }

    .step-btn {
      height: 48px;
      border-radius: 10px;
      border: none;
      font-size: 22px;
      font-weight: 500;
      cursor: pointer;
      background: var(--border);
      color: var(--text);
      transition: background 0.1s, transform 0.08s;
    }
    .step-btn:active { transform: scale(0.95); background: #3a3a3c; }

    .delay-presets { display: flex; gap: 8px; margin-top: 14px; }

    .preset-btn {
      flex: 1;
      height: 36px;
      border-radius: 8px;
      border: 1.5px solid var(--border);
      background: transparent;
      color: var(--text-dim);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.12s;
    }
    .preset-btn:active { background: var(--border); }
    .preset-btn.active {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(10,132,255,0.1);
    }

    /* Skip-by-N row */
    .skip-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-top: 12px;
    }
    .skip-btn {
      height: 44px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.1s, transform 0.08s;
    }
    .skip-btn:active { transform: scale(0.95); background: var(--border); }

    /* Segmented control (Linear / Random) */
    .segmented {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      background: #2c2c2e;
      border-radius: 10px;
      padding: 4px;
    }
    .seg-btn {
      height: 40px;
      border: none;
      background: transparent;
      color: var(--text-dim);
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      border-radius: 8px;
      transition: background 0.15s, color 0.15s;
    }
    .seg-btn.active {
      background: var(--accent);
      color: #fff;
    }

    /* Album list */
    .album-list {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .album-btn {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      width: 100%;
      min-height: 44px;
      padding: 0 14px;
      border-radius: 10px;
      border: 1.5px solid var(--border);
      background: #2c2c2e;
      color: var(--text);
      font-size: 15px;
      font-weight: 500;
      text-align: left;
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s, transform 0.08s;
    }
    .album-btn:active { transform: scale(0.98); }
    .album-btn.active {
      border-color: var(--accent);
      background: rgba(10,132,255,0.12);
      color: #fff;
    }
    .album-type {
      font-size: 11px;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .album-empty {
      color: var(--text-dim);
      font-size: 13px;
      padding: 4px 0;
    }

    /* Birthday-mode controls */
    .toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .toggle-label { font-size: 16px; font-weight: 500; }
    .toggle {
      width: 52px; height: 32px;
      border-radius: 18px;
      background: var(--border);
      border: none;
      position: relative;
      cursor: pointer;
      transition: background 0.2s;
      flex-shrink: 0;
    }
    .toggle::after {
      content: "";
      position: absolute;
      top: 3px; left: 3px;
      width: 26px; height: 26px;
      border-radius: 50%;
      background: #fff;
      transition: transform 0.2s;
    }
    .toggle.on { background: #32d74b; }
    .toggle.on::after { transform: translateX(20px); }

    .date-row { margin-top: 14px; }
    .date-label {
      display: block;
      font-size: 12px;
      color: var(--text-dim);
      margin-bottom: 6px;
    }
    .date-input {
      width: 100%;
      height: 44px;
      padding: 0 12px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: #2c2c2e;
      color: var(--text);
      font-size: 16px;
      font-family: inherit;
      color-scheme: dark;
    }
    .date-input:focus { outline: 1.5px solid var(--accent); border-color: var(--accent); }

    #connection-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #ff453a;
      display: inline-block;
      margin-right: 6px;
      transition: background 0.3s;
    }
    #connection-dot.connected { background: #32d74b; }
    #conn-label { font-size: 12px; color: var(--text-dim); }
  </style>
</head>
<body>
  <h1>Slideshow Remote</h1>

  <div class="card">
    <div class="card-title">Album</div>
    <div class="album-list" id="album-list">
      <button class="album-btn <%= 'active' if @settings['selected_album_id'].nil? %>"
              data-album-id="">All albums</button>
      <% @albums.each do |id, name, type| %>
        <button class="album-btn <%= 'active' if @settings['selected_album_id'].to_i == id %>"
                data-album-id="<%= id %>">
          <span><%= name %></span>
          <% if type != 'local' %><span class="album-type"><%= type %></span><% end %>
        </button>
      <% end %>
      <% if @albums.empty? %>
        <div class="album-empty">No albums yet — drop JPEGs into <code>public/slides/</code>.</div>
      <% end %>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Playback</div>
    <button id="play-pause-btn">
      <span id="pp-icon">&#9208;</span>
      <span id="pp-label">Pause</span>
    </button>
    <div class="skip-row">
      <button class="skip-btn" data-delta="-100">&minus;100</button>
      <button class="skip-btn" data-delta="-10">&minus;10</button>
      <button class="skip-btn" data-delta="10">+10</button>
      <button class="skip-btn" data-delta="100">+100</button>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Play Mode</div>
    <div class="segmented" id="play-mode">
      <button class="seg-btn <%= 'active' if @settings['play_mode'] == 'linear' %>"
              data-mode="linear">Linear</button>
      <button class="seg-btn <%= 'active' if @settings['play_mode'] == 'random' %>"
              data-mode="random">Random</button>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Navigation</div>
    <button id="reset-btn">&#8617; Reset to beginning</button>
  </div>

  <div class="card">
    <div class="card-title">Slide Delay</div>
    <div class="delay-row">
      <div>
        <div class="delay-display"><span id="delay-val">5</span></div>
        <div class="delay-unit">seconds</div>
      </div>
      <div class="stepper">
        <button class="step-btn" id="delay-up">+</button>
        <button class="step-btn" id="delay-down">&minus;</button>
      </div>
    </div>
    <div class="delay-presets">
      <button class="preset-btn" data-val="3">3s</button>
      <button class="preset-btn active" data-val="5">5s</button>
      <button class="preset-btn" data-val="10">10s</button>
      <button class="preset-btn" data-val="15">15s</button>
      <button class="preset-btn" data-val="30">30s</button>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Birthday Mode</div>
    <div class="toggle-row">
      <span class="toggle-label">Show timeline</span>
      <button id="birthday-toggle"
              class="toggle <%= 'on' if @settings['birthday_mode'] %>"
              aria-label="Toggle birthday mode"></button>
    </div>
    <div class="date-row">
      <label class="date-label" for="birthday-input">Birthday</label>
      <input id="birthday-input"
             class="date-input"
             type="date"
             value="<%= @settings['birthday'] %>">
    </div>
  </div>

  <div>
    <span id="connection-dot"></span>
    <span id="conn-label">Connecting&hellip;</span>
  </div>

  <script type="module">
    import { subscribeChannel } from "/javascript/cable.js";

    const COMMAND_URL = "<%= remote_command_path %>";
    let playing       = true;
    let delay         = 5;
    let birthdayMode  = <%= @settings['birthday_mode'] ? 'true' : 'false' %>;
    let birthday      = <%= @settings['birthday'].to_s.empty? ? 'null' : @settings['birthday'].to_json.html_safe %>;

    async function send(params) {
      await fetch(COMMAND_URL, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams(params).toString()
      });
    }

    // ── Delay ────────────────────────────────────────────────────────────
    function setDelay(val) {
      delay = Math.max(1, val);
      document.getElementById("delay-val").textContent = delay;
      document.querySelectorAll(".preset-btn").forEach(b => {
        b.classList.toggle("active", parseInt(b.dataset.val) === delay);
      });
      send({ action_name: "set_delay", delay });
    }

    // ── Play/Pause ───────────────────────────────────────────────────────
    function setPlaying(val) {
      playing = val;
      const btn   = document.getElementById("play-pause-btn");
      const icon  = document.getElementById("pp-icon");
      const label = document.getElementById("pp-label");
      if (playing) {
        btn.className = "";
        icon.textContent  = "⏸";
        label.textContent = "Pause";
      } else {
        btn.className = "paused";
        icon.textContent  = "▶";
        label.textContent = "Play";
      }
    }

    document.getElementById("play-pause-btn").addEventListener("click", () => {
      const next = !playing;
      setPlaying(next);
      send({ action_name: next ? "play" : "pause" });
    });

    document.getElementById("reset-btn").addEventListener("click", () => {
      setPlaying(true);
      send({ action_name: "reset" });
    });

    // ── Album selection ─────────────────────────────────────────────────
    document.querySelectorAll("#album-list .album-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll("#album-list .album-btn")
          .forEach(b => b.classList.toggle("active", b === btn));
        send({ action_name: "set_album", album_id: btn.dataset.albumId });
      });
    });

    // ── Play mode (linear / random) ──────────────────────────────────────
    document.querySelectorAll("#play-mode .seg-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll("#play-mode .seg-btn")
          .forEach(b => b.classList.toggle("active", b === btn));
        send({ action_name: "set_play_mode", mode: btn.dataset.mode });
      });
    });

    document.querySelectorAll(".skip-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        send({ action_name: "skip", delta: parseInt(btn.dataset.delta, 10) });
      });
    });

    document.getElementById("delay-up").addEventListener("click",   () => setDelay(delay + 1));
    document.getElementById("delay-down").addEventListener("click", () => setDelay(delay - 1));

    document.querySelectorAll(".preset-btn").forEach(btn => {
      btn.addEventListener("click", () => setDelay(parseInt(btn.dataset.val)));
    });

    // ── Birthday Mode ────────────────────────────────────────────────────
    const toggle      = document.getElementById("birthday-toggle");
    const dateInput   = document.getElementById("birthday-input");

    toggle.addEventListener("click", () => {
      birthdayMode = !birthdayMode;
      toggle.classList.toggle("on", birthdayMode);
      send({ action_name: "set_birthday_mode", enabled: birthdayMode });
    });

    dateInput.addEventListener("change", () => {
      birthday = dateInput.value || null;
      send({ action_name: "set_birthday", birthday: birthday || "" });
    });

    // ── Connection status ────────────────────────────────────────────────
    const dot   = document.getElementById("connection-dot");
    const label = document.getElementById("conn-label");

    subscribeChannel("SlideshowChannel", {
      connected()    { dot.className = "connected"; label.textContent = "Connected"; },
      disconnected() { dot.className = "";          label.textContent = "Disconnected"; },
      received()     {}
    });
  </script>
</body>
</html>
