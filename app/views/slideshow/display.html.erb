<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Slideshow</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%; height: 100%;
      background: #000;
      overflow: hidden;
    }

    #slideshow {
      position: relative;
      width: 100vw;
      height: 100vh;
    }

    .slide {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.8s ease-in-out;
      pointer-events: none;
    }

    .slide.active { opacity: 1; }

    .slide img {
      max-width: 100vw;
      max-height: 100vh;
      width: auto;
      height: auto;
      object-fit: contain;
      display: block;
    }

    #status {
      position: fixed;
      bottom: 16px;
      right: 16px;
      color: rgba(255,255,255,0.35);
      font-family: sans-serif;
      font-size: 13px;
      pointer-events: none;
      user-select: none;
    }

    #empty {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.6);
      font-family: sans-serif;
      font-size: 18px;
      text-align: center;
      padding: 24px;
    }
  </style>
</head>
<body>
  <% if @images.empty? %>
    <div id="empty">
      No images found.<br>
      Add JPEG files to <code>public/slides/</code> and reload.
    </div>
  <% else %>
    <div id="slideshow">
      <% @images.each_with_index do |img, i| %>
        <div class="slide <%= 'active' if i == 0 %>" data-index="<%= i %>">
          <img src="<%= img %>" alt="Slide <%= i + 1 %>" loading="<%= i < 3 ? 'eager' : 'lazy' %>">
        </div>
      <% end %>
    </div>

    <div id="status">&#9654; 1 / <%= @images.size %></div>

    <script type="module">
      import { subscribeChannel } from "/javascript/cable.js";

      const slides      = document.querySelectorAll(".slide");
      const statusEl    = document.getElementById("status");
      const totalSlides = slides.length;

      let currentIndex = 0;
      let delay        = 5000;   // ms
      let playing      = true;
      let timer        = null;

      function showSlide(index) {
        slides[currentIndex].classList.remove("active");
        currentIndex = ((index % totalSlides) + totalSlides) % totalSlides;
        slides[currentIndex].classList.add("active");
        updateStatus();
      }

      function updateStatus() {
        const icon = playing ? "▶" : "⏸";
        statusEl.textContent = `${icon} ${currentIndex + 1} / ${totalSlides}`;
      }

      function startTimer() {
        clearInterval(timer);
        timer = setInterval(() => {
          if (playing) showSlide(currentIndex + 1);
        }, delay);
      }

      startTimer();

      subscribeChannel("SlideshowChannel", {
        received(data) {
          switch (data.action) {
            case "play":
              playing = true;
              startTimer();
              updateStatus();
              break;

            case "pause":
              playing = false;
              clearInterval(timer);
              updateStatus();
              break;

            case "reset":
              playing = true;
              showSlide(0);
              startTimer();
              break;

            case "set_delay":
              delay = data.delay * 1000;
              if (playing) startTimer();
              break;
          }
        }
      });
    </script>
  <% end %>
</body>
</html>
