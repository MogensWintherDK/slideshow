<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin · Slideshow</title>
  <%= csrf_meta_tags %>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0f0f0f;
      --surface:  #1c1c1e;
      --surface2: #232325;
      --border:   #2c2c2e;
      --accent:   #0a84ff;
      --danger:   #ff453a;
      --good:     #32d74b;
      --text:     #f2f2f7;
      --text-dim: #8e8e93;
      --radius:   12px;
    }

    html, body {
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      font-size: 14px;
      line-height: 1.4;
    }

    .topbar {
      position: sticky; top: 0;
      background: rgba(15,15,15,0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      gap: 24px;
      z-index: 10;
    }
    .topbar h1 {
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -0.2px;
    }
    .topbar nav { display: flex; gap: 4px; }
    .topbar nav a {
      color: var(--text-dim);
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 8px;
      font-weight: 500;
      transition: background 0.12s, color 0.12s;
    }
    .topbar nav a:hover { background: var(--surface); color: var(--text); }
    .topbar nav a.active { background: var(--surface); color: var(--text); }
    .topbar .spacer { flex: 1; }
    .topbar .ext a {
      color: var(--text-dim);
      text-decoration: none;
      font-size: 13px;
      margin-left: 14px;
    }
    .topbar .ext a:hover { color: var(--accent); }

    main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 28px 24px 64px;
    }

    h2 {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.3px;
      margin-bottom: 18px;
    }
    h3 {
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--text-dim);
      margin: 28px 0 12px;
    }
    h3:first-child { margin-top: 0; }

    .flash {
      padding: 12px 16px;
      border-radius: 10px;
      margin-bottom: 18px;
      font-weight: 500;
    }
    .flash.notice { background: rgba(50,215,75,0.12); color: var(--good); }
    .flash.alert  { background: rgba(255,69,58,0.12);  color: var(--danger); }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
      margin-bottom: 24px;
    }
    .stat {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 18px;
    }
    .stat .label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--text-dim);
      font-weight: 600;
    }
    .stat .value {
      font-size: 28px;
      font-weight: 700;
      margin-top: 6px;
      letter-spacing: -0.5px;
    }
    .stat .sub {
      font-size: 12px;
      color: var(--text-dim);
      margin-top: 2px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }
    th, td {
      text-align: left;
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    th {
      background: var(--surface2);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: var(--text-dim);
      font-weight: 600;
    }
    tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: rgba(255,255,255,0.02); }
    td.num { text-align: right; font-variant-numeric: tabular-nums; }
    td.mono { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 13px; color: var(--text-dim); }
    td a { color: var(--accent); text-decoration: none; }
    td a:hover { text-decoration: underline; }

    .tag {
      display: inline-block;
      background: var(--border);
      color: var(--text-dim);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 2px 8px;
      border-radius: 6px;
    }
    .tag.local { background: rgba(10,132,255,0.18); color: #75b8ff; }

    button, .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--accent);
      color: #fff;
      border: none;
      padding: 8px 14px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.12s, transform 0.08s;
    }
    button:hover, .btn:hover { background: #1c92ff; }
    button:active, .btn:active { transform: scale(0.97); }
    .btn.subtle {
      background: var(--surface);
      color: var(--text);
      border: 1px solid var(--border);
    }
    .btn.subtle:hover { background: var(--surface2); }

    .btn.danger {
      background: var(--surface);
      color: var(--danger);
      border: 1px solid var(--danger);
    }
    .btn.danger:hover { background: rgba(255,69,58,0.12); }

    .row-actions { display: flex; gap: 8px; flex-wrap: wrap; }

    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 16px;
      margin-top: 18px;
      color: var(--text-dim);
      font-size: 13px;
    }
    .pagination a {
      color: var(--accent);
      text-decoration: none;
      padding: 6px 10px;
      border-radius: 6px;
      border: 1px solid var(--border);
    }
    .pagination a:hover { background: var(--surface); }
    .pagination .disabled { color: #444; padding: 6px 10px; }

    .thumb {
      width: 72px;
      height: 48px;
      object-fit: cover;
      border-radius: 4px;
      display: block;
      background: #000;
    }

    /* Live screen grid */
    .screen-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }
    .screen-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .screen-card-head {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .screen-code {
      font-family: ui-monospace, SFMono-Regular, monospace;
      font-weight: 700;
      letter-spacing: 2px;
      font-size: 16px;
      color: var(--text);
    }
    .screen-nick {
      flex: 1;
      color: var(--text-dim);
      font-size: 13px;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .screen-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--border);
      flex-shrink: 0;
    }
    .screen-dot.online { background: var(--good); }
    .screen-preview {
      width: 100%;
      aspect-ratio: 16 / 9;
      background: #000;
      border-radius: 8px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.35);
      font-size: 12px;
    }
    .screen-preview img {
      width: 100%; height: 100%;
      object-fit: contain;
      display: block;
    }
    .screen-footer {
      font-size: 12px;
      color: var(--text-dim);
      display: flex;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
    }

    input[type="text"] {
      background: #2c2c2e;
      border: 1px solid var(--border);
      color: var(--text);
      padding: 6px 10px;
      border-radius: 8px;
      font-family: inherit;
      font-size: 14px;
      min-width: 0;
    }
    input[type="text"]:focus { outline: 1.5px solid var(--accent); border-color: var(--accent); }
    form.inline { display: inline-flex; gap: 6px; align-items: center; }

    .breadcrumb {
      color: var(--text-dim);
      font-size: 13px;
      margin-bottom: 10px;
    }
    .breadcrumb a { color: var(--accent); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }

    code { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 13px; }
    .muted { color: var(--text-dim); }
  </style>
</head>
<body>
  <% active = request.path %>
  <header class="topbar">
    <h1>Slideshow Admin</h1>
    <nav>
      <a href="<%= admin_path %>"           class="<%= 'active' if active == admin_path %>">Dashboard</a>
      <a href="<%= admin_albums_path %>"    class="<%= 'active' if active.start_with?(admin_albums_path) %>">Albums</a>
      <a href="<%= admin_images_path %>"    class="<%= 'active' if active.start_with?(admin_images_path) %>">Images</a>
      <a href="<%= admin_locations_path %>" class="<%= 'active' if active.start_with?(admin_locations_path) %>">Locations</a>
      <a href="<%= admin_screens_path %>"   class="<%= 'active' if active.start_with?(admin_screens_path) %>">Screens</a>
      <a href="<%= admin_groups_path %>"    class="<%= 'active' if active.start_with?(admin_groups_path) %>">Groups</a>
    </nav>
    <div class="spacer"></div>
    <div class="ext">
      <a href="/" target="_blank">Slideshow ↗</a>
      <a href="<%= remote_path %>" target="_blank">Remote ↗</a>
    </div>
  </header>

  <main>
    <% if notice %><div class="flash notice"><%= notice %></div><% end %>
    <% if alert  %><div class="flash alert"><%= alert  %></div><% end %>
    <%= yield %>
  </main>
</body>
</html>
